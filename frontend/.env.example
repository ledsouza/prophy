# ---------------------------------------------------------------------------
# Backend connection
# ---------------------------------------------------------------------------

# Base URL of the Django backend.
# Local: http://localhost:8000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_HOST=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Client-side log level: trace | debug | info | warn | error | fatal
# Default: info
NEXT_PUBLIC_LOG_LEVEL=

# Optional endpoint that receives JSON logs via POST/sendBeacon.
# When unset, logs stay console-only.
NEXT_PUBLIC_LOG_ENDPOINT=

# ---------------------------------------------------------------------------
# Build metadata (optional)
# ---------------------------------------------------------------------------

# Version string included in log metadata.
# Set to a git SHA, semver tag, or "local" for development.
NEXT_PUBLIC_APP_VERSION=
