# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------

# Required. Run: python -c "from django.core.management.utils import
# get_random_secret_key; print(get_random_secret_key())" to generate.
# Production value lives in Secret Manager — never reuse the dev value.
DJANGO_SECRET_KEY=

# True for local development, False everywhere else.
DEBUG=

# Comma-separated list of allowed hostnames.
# Local: 127.0.0.1,localhost
# Production: api.yourdomain.com
DJANGO_ALLOWED_HOSTS=

# ---------------------------------------------------------------------------
# Cross-origin / CSRF (production only — omit or leave blank for local dev)
# ---------------------------------------------------------------------------

# Comma-separated list of trusted CSRF origins.
# Required in production (e.g. https://app.yourdomain.com).
CSRF_TRUSTED_ORIGINS=

# Comma-separated list of allowed CORS origins.
# Required in production (e.g. https://app.yourdomain.com).
CORS_ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Frontend integration
# ---------------------------------------------------------------------------

# Base URL of the frontend, used in email links and CORS defaults.
# Local default: http://localhost:3000
FRONTEND_URL=

# ---------------------------------------------------------------------------
# Auth cookies
# ---------------------------------------------------------------------------

# True in production (HTTPS), False for local HTTP.
AUTH_COOKIE_SECURE=

# ---------------------------------------------------------------------------
# Authentication — OIDC
# ---------------------------------------------------------------------------

# Audience string for Google OIDC token validation.
# Required in production; can be omitted locally (no OIDC flow).
OIDC_AUDIENCE=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Leave unset (or "sqlite") for local SQLite.
# Set to "postgres" to use PostgreSQL.
DATABASE_ENGINE=

# Option A — single connection string (takes precedence when set).
DATABASE_URL=

# Option B — individual Postgres connection fields
# (used only when DATABASE_ENGINE=postgres and DATABASE_URL is not set).
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=

# ---------------------------------------------------------------------------
# Storage — Google Cloud Storage (production only)
# ---------------------------------------------------------------------------

# Required when using core.settings.prod.
# Cloud Run uses Application Default Credentials — no key file needed.
GCS_BUCKET_NAME=

# ---------------------------------------------------------------------------
# Email — Mailgun
# ---------------------------------------------------------------------------

# Mailgun API key. Rotate before first production deploy.
# Production value lives in Secret Manager.
MAILGUN_API_KEY=

# Mailgun sender domain (e.g. mg.yourdomain.com).
DOMAIN=

# Optional override for the Mailgun API endpoint.
# Default: https://api.mailgun.net/v3
MAILGUN_API_URL=

# Default sender address for outbound emails.
DEFAULT_FROM_EMAIL=

# ---------------------------------------------------------------------------
# Notifications (optional)
# ---------------------------------------------------------------------------

# Comma-separated email list. When set, all notifications are redirected
# here instead of real recipients (useful for staging).
NOTIFICATION_OVERRIDE_RECIPIENTS=
